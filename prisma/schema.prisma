generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

enum LeadType {
  CONTACT
  QUOTE
  EMERGENCY
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String
  message   String?
  type      LeadType
  status    LeadStatus @default(NEW)
  page      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PageVisit {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  ipHash    String?
  createdAt DateTime @default(now())
}

model PhoneClick {
  id        String   @id @default(cuid())
  page      String
  device    String?
  source    String?
  createdAt DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())
  authorName String
  rating     Int
  text       String?
  time       DateTime
  source     String   @default("google")
  createdAt  DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PlatformStatus {
  PRESENT
  TO_CHECK
  ABSENT
}

model PlatformPresence {
  id        String         @id @default(cuid())
  name      String         @unique
  url       String?
  status    PlatformStatus @default(TO_CHECK)
  updatedAt DateTime       @updatedAt
}

model DailyStats {
  id           String   @id @default(cuid())
  date         DateTime @unique
  pageViews    Int      @default(0)
  uniqueVisits Int      @default(0)
  phoneClicks  Int      @default(0)
  leads        Int      @default(0)
}
